"generate_question": {
    "pl": {
      "persona": "Ekspert quizowy. Generuj tylko JSON.",
      "static_instructions": [
        "WYMAGANIA:",
        "1. ANTY-CLICHÉ: Zignoruj 3 pierwsze skojarzenia dla tej kategorii. Szukaj wyjątków, nie reguł.",
        "2. UNIKALNOŚĆ: Sprawdź ZAKAZANE. Jeśli temat jest popularny, znajdź jego niszowy aspekt.",
        "3. OBIEKTYWIZM: 1 poprawna odpowiedź. Żadnych opinii.",
        "4. ZWIĘZŁOŚĆ: Pytanie <20 słów. Opcje <5 słów. Wyjaśnienia max 1 zdanie.",
        "5. BRAK SPOILERA: Odpowiedź nie może paść w pytaniu.",
        "6. DYSTRAKTORY: Błędne opcje muszą być wiarygodne.",
        "7. FORMAT JSON (bez markdown):",
        "{{\n  \"question\": \"Treść...\",\n  \"answer\": \"Poprawna...\",\n  \"subcategory\": \"Precyzyjna podkategoria\",\n  \"key_entities\": [\"KluczoweNazwy\"],\n  \"options\": [\"A\", \"B\", \"C\", \"D\"],\n  \"explanation_correct\": \"Fakt weryfikujący.\",\n  \"explanation_distractors\": \"Dlaczego błędne.\"\n}}"
      ],
      "task_template": "ZADANIE:\nKat: \"{category}\"\nTrudność: {knowledge_prompt}\nTryb: {game_mode_prompt}\nMotyw: {theme_context}\n\nZAKAZANE (Unikaj tych haseł):\n- Podkategorie: {subcategory_history_prompt}\n- Nazwy: {entity_history_prompt}"
    },
    "en": {
      "persona": "Quiz expert. Generate JSON only.",
      "static_instructions": [
        "REQUIREMENTS:",
        "1. ANTI-CLICHÉ: Discard the first 3 associations that come to mind. Focus on exceptions, not rules.",
        "2. UNIQUENESS: Check FORBIDDEN. If topic is popular, find an obscure angle.",
        "3. OBJECTIVITY: 1 correct answer. No opinions.",
        "4. CONCISE: Question <20 words. Options <5 words. Explanations max 1 sentence.",
        "5. NO SPOILERS: Answer not in question text.",
        "6. DISTRACTORS: Plausible incorrect options.",
        "7. JSON FORMAT (no markdown):",
        "{{\n  \"question\": \"Text...\",\n  \"answer\": \"Correct...\",\n  \"subcategory\": \"Precise subcategory\",\n  \"key_entities\": [\"KeyEntities\"],\n  \"options\": [\"A\", \"B\", \"C\", \"D\"],\n  \"explanation_correct\": \"Verification fact.\",\n  \"explanation_distractors\": \"Why incorrect.\"\n}}"
      ],
      "task_template": "TASK:\nCat: \"{category}\"\nDiff: {knowledge_prompt}\nMode: {game_mode_prompt}\nTheme: {theme_context}\n\nFORBIDDEN (Avoid these):\n- Subcats: {subcategory_history_prompt}\n- Entities: {entity_history_prompt}"
    }
  },
  "generate_categories": {
    "pl": {
      "static_instructions": [
        "Generuj 6 szerokich kategorii PASUJĄCYCH DO MOTYWU.",
        "Zachowaj różnorodność (ludzie, miejsca, wydarzenia, kultura).",
        "Zwróć JSON: {{\n  \"categories\": [\"K1\", \"K2\", \"K3\", \"K4\", \"K5\", \"K6\"]\n}}"
      ],
      "task_template": "Motyw: \"{theme}\""
    },
    "en": {
      "static_instructions": [
        "Generate 6 broad categories MATCHING THE THEME.",
        "Ensure diversity (people, places, events, culture).",
        "Return JSON: {{\n  \"categories\": [\"C1\", \"C2\", \"C3\", \"C4\", \"C5\", \"C6\"]\n}}"
      ],
      "task_template": "Theme: \"{theme}\""
    }
  },
  "mutate_category": {
    "pl": {
      "static_instructions": [
        "Zaproponuj 5 alternatyw dla kategorii PASUJĄCYCH DO MOTYWU.",
        "Zasady: Ten sam poziom ogólności, inny kontekst, bez synonimów.",
        "Zwróć JSON: {{\n  \"choices\": [\n    {{\"name\": \"...\", \"description\": \"...\"}}\n  ]\n}}"
      ],
      "task_template": "Kategoria: \"{old_category}\"\nMotyw: \"{theme}\"\nUnikaj: {existing_categories}"
    },
    "en": {
      "static_instructions": [
        "Propose 5 alternatives for the category MATCHING THE THEME.",
        "Rules: Same level, different context, no synonyms.",
        "Return JSON: {{\n  \"choices\": [\n    {{\"name\": \"...\", \"description\": \"...\"}}\n  ]\n}}"
      ],
      "task_template": "Category: \"{old_category}\"\nTheme: \"{theme}\"\nAvoid: {existing_categories}"
    }
  },
  "explain_incorrect": {
    "pl": {
      "static_instructions": [
        "Oceń odpowiedź. Werdykt: 'player' (uznana) lub 'game' (odrzucona).",
        "Wyjaśnienie: krótkie, neutralne.",
        "Zwróć JSON: {{\n  \"verdict_for\": \"...\",\n  \"verdict_certainty\": 0-100,\n  \"explanation\": \"...\"\n}}"
      ],
      "task_template": "Pytanie: \"{question}\"\nPoprawna: \"{correct_answer}\"\nGracz: \"{player_answer}\""
    },
    "en": {
      "static_instructions": [
        "Judge answer. Verdict: 'player' (accepted) or 'game' (rejected).",
        "Explanation: short, neutral.",
        "Return JSON: {{\n  \"verdict_for\": \"...\",\n  \"verdict_certainty\": 0-100,\n  \"explanation\": \"...\"\n}}"
      ],
      "task_template": "Q: \"{question}\"\nCorrect: \"{correct_answer}\"\nPlayer: \"{player_answer}\""
    }
  }
}